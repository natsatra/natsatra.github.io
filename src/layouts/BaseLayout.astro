---
import { GoogleAnalytics } from 'astro-google-analytics';
import { ClientRouter } from 'astro:transitions';
import BaseHead, { type Props as HeadProps } from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Nav from '../components/Nav.astro';

export type Props = HeadProps & { showHeader?: boolean };

const { showHeader = true, ...head } = Astro.props;
---

<!doctype html>
<html lang="en" class="wrap-break-words antialiased">
    <head>
        <BaseHead {...head} />
        <script is:inline>
    function applyDarkBackground() {
        document.documentElement.classList.add('dark');
        document.documentElement.style.background = 'var(--bg-base)';
        document.documentElement.style.backgroundImage = 'var(--bg-gradient)';
        if (document.body) {
            document.body.style.background = 'var(--bg-base)';
            document.body.style.backgroundImage = 'var(--bg-gradient)';
        }
    }
    applyDarkBackground();
    document.addEventListener('DOMContentLoaded', applyDarkBackground);
    document.addEventListener('astro:before-swap', applyDarkBackground);
    document.addEventListener('astro:after-swap', applyDarkBackground);
</script>
<ClientRouter />
<GoogleAnalytics id="G-FB6207101F" />
    </head>
    <body class="text-main" style="min-height: 100vh;">
        <div
            class="pointer-events-none fixed inset-0 z-0 bg-repeat opacity-10"
            style="background-image: url('/texture.svg');"
        >
        </div>
        <div class="relative z-10 flex min-h-screen flex-col px-4 md:px-8">
            <Nav />
            {showHeader && <Header />}
            <main class="mx-auto w-full max-w-3xl grow">
                <slot />
            </main>
            <Footer />
        </div>
    </body>
</html>
